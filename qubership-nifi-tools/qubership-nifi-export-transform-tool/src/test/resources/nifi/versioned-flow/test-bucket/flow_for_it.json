				"properties": {
					"Failure Strategy": "rollback",
					"Script Body": "import org.apache.nifi.processor.io.StreamCallback\nimport java.nio.charset.StandardCharsets\nimport groovy.json.JsonSlurper\nimport groovy.json.JsonOutput\n\ndef flowFile = session.get()\nif (!flowFile) return\n\nflowFile = session.write(flowFile, { inputStream, outputStream ->\n    def json = new JsonSlurper().parse(inputStream, \"UTF-8\")\n    \n    if (json.containsKey(\"attributeName\")) {\n        flowFile = session.putAttribute(flowFile, \"attributeName\", json.attributeName?.toString() ?: \"\")\n    }\n    if (json.containsKey(\"attributeValue\")) {\n        flowFile = session.putAttribute(flowFile, \"attributeValue\", json.attributeValue?.toString() ?: \"\")\n    }\n    \n    def now = new Date().format(\"yyyy-MM-dd'T'HH:mm:ss.SSSZ\", TimeZone.getTimeZone(\"UTC\"))\n    json.current_data = now\n    \n    def prettyJson = JsonOutput.prettyPrint(JsonOutput.toJson(json))\n    outputStream.write(prettyJson.getBytes(StandardCharsets.UTF_8))\n} as StreamCallback)\n\nsession.transfer(flowFile, REL_SUCCESS)"
				},
